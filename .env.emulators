# =============================================================================
# Eulard — Emulator / CI Environment Variables
# Used for running tests and CI pipelines against local services.
# =============================================================================

# --- Database (docker-compose postgres) ---
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=eulard
DB_USER=eulard-app
DB_PASSWORD=localdev
DB_SSL=false

# --- NextAuth (deterministic secret for test reproducibility) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret-do-not-use-in-production
AUTH_TRUST_HOST=true

# --- Google OAuth (disabled in emulator mode) ---
AUTH_GOOGLE_CLIENT_ID=fake-client-id
AUTH_GOOGLE_CLIENT_SECRET=fake-client-secret
AUTH_GOOGLE_ALLOWED_DOMAINS=test.local

# --- Anthropic AI (disabled — tests should mock AI calls) ---
ANTHROPIC_API_KEY=sk-ant-test-fake-key

# --- Admin ---
ADMIN_EMAILS=admin@test.local

# --- Test flags ---
NODE_ENV=test
