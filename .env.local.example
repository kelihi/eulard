# =============================================================================
# Eulard Local Development Environment
# Copy this file to .env.local and fill in values.
# To pull real secrets from GCP: ./scripts/pull-secrets.sh
# =============================================================================

# --- Database (local docker-compose postgres on port 5433) ---
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=eulard
DB_USER=eulard-app
DB_PASSWORD=localdev
DB_SSL=false

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-secret-change-me-in-production
AUTH_TRUST_HOST=true

# --- Google OAuth (optional for local — use credentials login instead) ---
# Get these from: https://console.cloud.google.com/apis/credentials
# Or pull from GCP: ./scripts/pull-secrets.sh
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_ALLOWED_DOMAINS=kelihi.com

# --- Anthropic AI (required for AI features) ---
# Pull from GCP: ./scripts/pull-secrets.sh
ANTHROPIC_API_KEY=

# --- Admin ---
ADMIN_EMAILS=admin@test.local
